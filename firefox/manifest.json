{
  "manifest_version": 2,
  "name": "tw-web",
  "version": "1.0",
  "description": "Bookmark current page as a Taskwarrior task via tw-web",
  "icons": { "48": "icon.png" },
  "browser_action": {
    "default_icon": "icon.png",
    "default_title": "Bookmark in Taskwarrior (Alt+W)",
    "default_popup": "popup.html"
  },
  "commands": {
    "_execute_browser_action": {
      "suggested_key": { "default": "Alt+W" },
      "description": "Open tw-web bookmark dialog"
    }
  },
  "permissions": ["activeTab", "tabs"]
}
