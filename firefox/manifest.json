{
  "manifest_version": 2,
  "name": "tw-web",
  "version": "1.1",
  "description": "Add tasks and bookmarks to Taskwarrior via tw-web",
  "icons": { "48": "icon.png" },
  "browser_specific_settings": {
    "gecko": { "id": "tw-web@linuxcaffe" }
  },
  "browser_action": {
    "default_icon": "icon.png",
    "default_title": "tw-web (Alt+W)",
    "default_popup": "popup.html"
  },
  "commands": {
    "_execute_browser_action": {
      "suggested_key": { "default": "Alt+W" },
      "description": "Open tw-web popup"
    }
  },
  "permissions": ["activeTab", "tabs", "nativeMessaging"]
}
